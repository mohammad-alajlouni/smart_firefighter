    {
        "id": "flow_tab_1",
        "type": "tab",
        "label": "Smart Firefighter System",
        "disabled": false,
        "info": "Smart Firefighter Wearable System Dashboard — receives live telemetry via MQTT (LoRa data-flow emulation)"
    },
    {
        "id": "mqtt_broker_cfg",
        "type": "mqtt-broker",
        "name": "EMQX Public Broker",
