    {
        "id": "mqtt_in_telemetry",
        "type": "mqtt in",
        "z": "flow_tab_1",
        "name": "Subscribe: Telemetry",
        "topic": "smart_firefighter/ff01/telemetry",
        "qos": "1",
        "datatype": "auto",
        "broker": "mqtt_broker_cfg",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 130,
        "y": 140,
        "wires": [["json_parse"]]
    },
    {
        "id": "mqtt_in_alerts",
        "type": "mqtt in",
        "z": "flow_tab_1",
        "name": "Subscribe: Alerts",
        "topic": "smart_firefighter/ff01/alerts",
        "qos": "1",
        "datatype": "auto",
        "broker": "mqtt_broker_cfg",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 130,
        "y": 620,
        "wires": [["json_alerts"]]
    },
    {
        "id": "json_parse",
        "type": "json",
        "z": "flow_tab_1",
        "name": "Parse Telemetry JSON",
        "property": "payload",
        "action": "obj",
        "pretty": false,
        "x": 370,
        "y": 140,
        "wires": [["func_hr", "func_temp", "func_co", "func_status", "func_fall", "func_alert", "func_info", "debug_raw"]]
    },
    {
        "id": "json_alerts",
        "type": "json",
        "z": "flow_tab_1",
        "name": "Parse Alert JSON",
        "property": "payload",
        "action": "obj",
        "pretty": false,
        "x": 370,
        "y": 620,
        "wires": [["func_event_log"]]
    },
    {
        "id": "debug_raw",
        "type": "debug",
        "z": "flow_tab_1",
        "name": "Raw Telemetry Debug",
        "active": true,
        "tosidebar": true,
        "console": false,
        "tostatus": false,
        "complete": "payload",
        "targetType": "msg",
        "statusVal": "",
        "statusType": "auto",
        "x": 650,
        "y": 60,
        "wires": []
    },
    {
        "id": "func_hr",
        "type": "function",
        "z": "flow_tab_1",
        "name": "Extract Heart Rate",
        "func": "msg.payload = msg.payload.heart_rate;\nmsg.topic = \"Heart Rate (BPM)\";\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 160,
        "wires": [["gauge_hr", "chart_hr"]]
    },
    {
        "id": "func_temp",
        "type": "function",
        "z": "flow_tab_1",
        "name": "Extract Body Temp",
        "func": "msg.payload = msg.payload.body_temp;\nmsg.topic = \"Body Temperature (°C)\";\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 220,
        "wires": [["gauge_temp", "chart_temp"]]
    },
    {
        "id": "func_co",
        "type": "function",
        "z": "flow_tab_1",
        "name": "Extract CO Level",
        "func": "msg.payload = msg.payload.co_level;\nmsg.topic = \"CO Level (ppm)\";\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 280,
        "wires": [["gauge_co", "chart_co"]]
    },
    {
        "id": "func_status",
        "type": "function",
        "z": "flow_tab_1",
        "name": "Format Status + Color",
        "func": "var status = msg.payload.status;\nvar colorMap = {\n    'OK':            '#00b500',\n    'WARNING':       '#e6a817',\n    'DANGER':        '#ca3838',\n    'FALL_DETECTED': '#8b008b'\n};\nmsg.payload = {\n    status: status,\n    color:  colorMap[status] || '#444444'\n};\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 340,
        "wires": [["ui_status_template"]]
    },
    {
        "id": "func_fall",
        "type": "function",
        "z": "flow_tab_1",
        "name": "Format Fall Detection",
        "func": "msg.payload = msg.payload.fall_detected\n    ? '⚠  FALL DETECTED'\n    : '✔  Normal — No Fall';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 400,
        "wires": [["text_fall"]]
    },
    {
        "id": "func_alert",
        "type": "function",
        "z": "flow_tab_1",
        "name": "Extract Alert Message",
        "func": "msg.payload = msg.payload.alert_message || 'No active alerts';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 460,
        "wires": [["text_alert"]]
    },
    {
        "id": "func_info",
        "type": "function",
        "z": "flow_tab_1",
        "name": "Extract ID + Timestamp",
        "func": "var id_msg = { payload: msg.payload.firefighter_id };\nvar ts_msg = { payload: msg.payload.timestamp };\nreturn [id_msg, ts_msg];",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 520,
        "wires": [["text_ff_id"], ["text_timestamp"]]
    },
    {
        "id": "func_event_log",
        "type": "function",
        "z": "flow_tab_1",
        "name": "Format Event Log Entry",
        "func": "var p = msg.payload;\nvar colorMap = {\n    'WARNING':       'orange',\n    'DANGER':        'red',\n    'FALL_DETECTED': 'purple'\n};\nmsg.payload = [\n    {\n        'time':    p.timestamp,\n        'id':      p.firefighter_id,\n        'status':  p.status,\n        'message': p.alert_message\n    }\n];\nmsg.color = colorMap[p.status] || 'grey';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 640,
        "y": 620,
        "wires": [["table_events", "debug_alerts"]]
    },
