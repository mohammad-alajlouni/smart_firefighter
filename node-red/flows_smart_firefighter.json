        "port": "1883",
        "clientid": "nodered_ff_dashboard",
        "usetls": false,
        "compatmode": false,
        "keepalive": "60",
        "cleansession": true,
        "birthTopic": "",
        "birthQos": "0",
        "birthPayload": "",
        "birthRetain": "false",
        "closeTopic": "",
        "closeQos": "0",
        "closePayload": "",
        "closeRetain": "false",
        "willTopic": "",
        "willQos": "0",
        "willPayload": "",
        "willRetain": "false",
        "sessionExpiry": ""
    },
