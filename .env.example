# ─── MQTT Broker Settings ─────────────────────────────────────────────────────
MQTT_BROKER_HOST=broker.emqx.io
MQTT_BROKER_PORT=1883
MQTT_TELEMETRY_TOPIC=smart_firefighter/ff01/telemetry
MQTT_ALERT_TOPIC=smart_firefighter/ff01/alerts

# ─── Firefighter Identity ──────────────────────────────────────────────────────
FIREFIGHTER_ID=FF-01

# ─── Publish Interval (seconds) ───────────────────────────────────────────────
PUBLISH_INTERVAL=2.0

# ─── Alert Thresholds — Heart Rate (BPM) ──────────────────────────────────────
HR_OK_MAX=110
HR_WARNING_MAX=130

# ─── Alert Thresholds — Body Temperature (°C) ─────────────────────────────────
TEMP_OK_MAX=38.0
TEMP_WARNING_MAX=39.5

# ─── Alert Thresholds — CO Level (ppm) ────────────────────────────────────────
CO_OK_MAX=50
CO_WARNING_MAX=200
